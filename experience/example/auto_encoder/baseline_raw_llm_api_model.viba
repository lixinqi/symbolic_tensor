
BaselineRawLlmApiModel[torch.nn.Module] :=
    # forward
    $baseline_output SymblicTensor[($total_batch_size,)]
    <- $masked_file_path_tensor Symbolic[Tensor[($total_batch_size, $num_files)]]
    <- $masked_file_content_tensor Symbolic[TensorTensor[($total_batch_size, $num_files)]]
    <- $ground_truth_content_tensor Symbolic[TensorTensor[($total_batch_size)]]
    # __init__
    <- ()
    #inline
    <- (
        $path_and_contents Symbolic[Tensor[($total_batch_size, $num_files)]]
        <- Import[function/merge]
        <- { concat on last axis }
        <- $masked_file_path_tensor
        <- $masked_file_content_tensor
    )
    <- (
        $merged_path_and_contents Symbolic[Tensor[($total_batch_size, 1)]]
        <- Import[function/merge]
        <- $path_and_contents
        <- $axis -1
    )
    <- ($prompt <- { Get back the original content that was masked in f"{kMaskedHint}" })
    <- (
        $baseline_output 
        <- Import[function/coding_agent.viba]
        <- $merged_path_and_contents
        <- $prompt
        <- $llm_method "raw_llm_api"
    )


DuccTaskHandler :=
    # __call__
    void
    <- NestedList[$agent_task Import[experience/llm_client/agent_task.viba]]
    <- $llm_env dict[str, str] # default None
    <- $interactive bool # default False
    <- $auto_confirm bool # default True
    <- $tmux_session str # default None
    # __init__
    <- ()
    # inline
    <- (($workspace_dir, $prompt) <- $agent_task)
    <- $ducc_bin _find_ducc_bin()
    <- $run_mode (if $interactive then "tmux" else "subprocess")
    <- $ducc_run (void <- $ducc_bin <- $prompt <- $workspace_dir <- $llm_env <- $run_mode)
    <- (void <- batch_run <- NestList[$ducc_run])

_find_ducc_bin :=
    # Find ducc binary in order of priority
    str
    <- ()
    # inline
    <- $env_bin os.environ.get("DUCC_BIN")
    <- $path_bin shutil.which("ducc")
    <- $glob_pattern "~/.comate/extensions/baidu.baidu-cc-*/resources/native-binary/bin/ducc"
    <- $glob_matches sorted(glob.glob($glob_pattern), reverse=True)
    <- (return $env_bin if $env_bin else $path_bin if $path_bin else $glob_matches[0])

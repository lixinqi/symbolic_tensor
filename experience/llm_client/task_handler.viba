
AgentTask := Import[experience/llm_client/agent_task.viba]

TaskHandler :=
    # __call__
    void
    <- NestList[AgentTask]
    <- $llm_method str
    <- $llm_env dict[str, str] # default None
    # __init__
    <- ()
    # inline
    <- GenerateOutput[$llm_method]

GenerateOutput["coding_agent"] :=
    void
    <- NestList[AgentTask]
    # inline
    <- Import[experience/llm_client/coding_agent_task_handler.viba]

GenerateOutput["raw_llm_api"] :=
    void
    <- NestList[AgentTask]
    # inline
    <- Import[experience/llm_client/raw_llm_task_handler.viba]

GenerateOutput["tmux_cc"] :=
    void
    <- NestList[AgentTask]
    <- $interactive bool # default False
    <- $auto_confirm bool # default True
    <- $tmux_session str # default None
    # inline
    <- Import[experience/llm_client/ducc_task_handler.viba]
